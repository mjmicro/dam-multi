# Database
MONGODB_URI=mongodb://mongo:27017/mediadb

# MongoDB
MONGO_PASSWORD=secure-mongo-pass-12345
MONGO_DATABASE=mediadb

# Redis
REDIS_PASSWORD=secure-redis-pass-67890

# MinIO
MINIO_USER=admin
MINIO_PASSWORD=secure-minio-pass-11111
MINIO_REGION=us-east-1

# API
NODE_ENV=production
ENVIRONMENT=production
REGISTRY=docker.io
VERSION=latest
CORS_ORIGIN=http://localhost:3001
MAX_UPLOAD_SIZE=200m
UPLOAD_TIMEOUT=300000
API_TIMEOUT=300000
SOCKET_TIMEOUT=300000
API_REPLICAS=1

# Redis
REDIS_URL=redis://redis:6379

# MinIO
MINIO_ENDPOINT=minio
MINIO_ENDPOINT_EXTERNAL=http://localhost:9002
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password

# Node
NODE_ENV=development

# MinIO Root
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password
