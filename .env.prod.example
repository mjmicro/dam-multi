# Production Environment Configuration
# Copy to .env.prod and fill in your values

# === Core Settings ===
ENVIRONMENT=production
NODE_ENV=production
LOG_LEVEL=info

# === MongoDB ===
MONGO_USER=admin
MONGO_PASSWORD=your-secure-password-here
MONGO_DATABASE=mediadb

# === Redis ===
REDIS_PASSWORD=your-secure-redis-password-here

# === MinIO ===
MINIO_USER=admin
MINIO_PASSWORD=your-secure-minio-password-here
MINIO_SERVER_URL=http://minio:9000
MINIO_BROWSER_URL=http://minio.yourdomain.com
MINIO_ENDPOINT_EXTERNAL=http://minio.yourdomain.com

# === API Configuration ===
API_IMAGE=dam-api
API_REPLICAS=3
CORS_ORIGIN=https://yourdomain.com
PORT=4000

# === Worker Configuration ===
WORKER_IMAGE=dam-worker
WORKER_REPLICAS=5
WORKER_CONCURRENCY=3

# === Client Configuration ===
CLIENT_IMAGE=dam-client
CLIENT_REPLICAS=2
VITE_API_URL=https://api.yourdomain.com

# === Registry Configuration ===
REGISTRY=your-registry.azurecr.io
VERSION=1.0.0

# === Advanced Settings ===
MAX_UPLOAD_SIZE=5000000000
SESSION_TIMEOUT=3600
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKUP_INTERVAL=300
