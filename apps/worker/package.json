{
  "name": "@dam/worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node\" src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dam/database": "workspace:*",
    "bullmq": "^5.0.0",
    "dotenv": "^16.3.1",
    "fluent-ffmpeg": "^2.1.2",
    "minio": "^7.1.3",
    "mongoose": "^7.3.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
