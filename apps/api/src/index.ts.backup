import express from 'express';
import mongoose, { Schema } from 'mongoose';
import * as Minio from 'minio';
import { Queue } from 'bullmq';
import IORedis from 'ioredis';

const app = express();
app.use(express.json());

const mongoUrl = process.env.DATABASE_URL || 'mongodb://mongo:27017/mediadb';

// Define Asset model
const AssetSchema = new Schema({
  filename: String,
  originalName: String,
  mimeType: String,
  size: Number,
  providerPath: String,
  status: String,
  createdAt: { type: Date, default: Date.now },
}, { collection: 'assets' });

let Asset: any = null;

// Initialize Mongoose
mongoose.connect(mongoUrl, { autoIndex: false }).then(() => {
  Asset = mongoose.models.Asset || mongoose.model('Asset', AssetSchema);
  console.log('✅ MongoDB connected');
}).catch(err => {
  console.error('❌ MongoDB connection failed:', err.message);
});

// 1. Infrastructure Connections
const redisConnection = new IORedis(process.env.REDIS_URL || 'redis://localhost:6379', { maxRetriesPerRequest: null });
const assetQueue = new Queue('asset-tasks', { connection: redisConnection });

const minioClient = new Minio.Client({
  endPoint: process.env.MINIO_ENDPOINT || 'minio',
  port: 9000,
  useSSL: false,
  accessKey: process.env.MINIO_ACCESS_KEY || 'admin',
  secretKey: process.env.MINIO_SECRET_KEY || 'password',
});

const minioExternalUrl = process.env.MINIO_ENDPOINT_EXTERNAL || 'http://localhost:9000';

// Initialize MinIO bucket
(async () => {
  try {
    const bucketExists = await minioClient.bucketExists('assets');
    if (!bucketExists) {
      await minioClient.makeBucket('assets', 'us-east-1');
      console.log('✅ MinIO bucket "assets" created');
    } else {
      console.log('✅ MinIO bucket "assets" exists');
    }
  } catch (err: any) {
    console.error('⚠️  MinIO bucket check/create failed:', err.message);
  }
})();

// 2. Route: Get Presigned URL for direct upload
app.get('/api/upload-url', async (req, res) => {
  const { fileName } = req.query;
  const objectName = `uploads/${Date.now()}-${fileName}`;
  
  try {
    const url = await minioClient.presignedPutObject('assets', objectName, 60 * 5); // 5 min expiry
    // Replace internal endpoint with external for clients
    const externalUrl = url.replace(`http://${process.env.MINIO_ENDPOINT || 'minio'}:9000`, minioExternalUrl);
    res.json({ url: externalUrl, objectName });
  } catch (err: any) {
    console.error('❌ Presigned URL generation failed:', err.message);
    res.status(500).json({ error: 'Failed to generate URL', details: err.message });
  }
});

// 3. Route: Direct file upload (uploads file to MinIO and creates asset record)
app.post('/api/upload', async (req, res) => {
  const { originalName, mimeType, data } = req.body;
  
  if (!originalName || !data) {
    return res.status(400).json({ error: 'originalName and data (base64) required' });
  }

  try {
    if (!Asset) {
      return res.status(503).json({ error: 'Database not initialized' });
    }

    const objectName = `uploads/${Date.now()}-${originalName}`;
    
    // Convert base64 to buffer
    const buffer = Buffer.from(data, 'base64');
    
    // Upload file to MinIO
    await minioClient.putObject('assets', objectName, buffer, buffer.length, {
      'Content-Type': mimeType || 'application/octet-stream',
    });
    
    console.log(`✅ File uploaded to MinIO: ${objectName} (${buffer.length} bytes)`);

    // Create asset record
    const asset = await Asset.create({
      filename: objectName,
      originalName,
      mimeType: mimeType || 'application/octet-stream',
      size: buffer.length,
      status: 'PENDING',
      providerPath: `assets/${objectName}`
    });

    // Queue processing job
    await assetQueue.add('process-media', {
      assetId: asset._id,
      objectName,
      mimeType
    });

    res.status(201).json({ 
      message: 'File uploaded and processing started',
      assetId: asset._id,
      objectName
    });
  } catch (err: any) {
    console.error('❌ Upload failed:', err.message);
    res.status(500).json({ error: 'Upload failed', details: err.message });
  }
});

// 3. Route: Finalize Upload & Queue Job
app.post('/api/finalize', async (req, res) => {
  const { objectName, originalName, mimeType, size } = req.body;

  try {
    if (!Asset) {
      return res.status(503).json({ error: 'Database not initialized' });
    }
    // Create PENDING record in MongoDB
    const asset = await Asset.create({
      filename: objectName,
      originalName,
      mimeType,
      size,
      status: 'PENDING',
      providerPath: `assets/${objectName}`
    });

    // Add to BullMQ for the worker to find
    await assetQueue.add('process-media', {
      assetId: asset._id,
      objectName,
      mimeType
    });

    res.status(202).json({ message: 'Processing started', assetId: asset._id });
  } catch (err: any) {
    res.status(500).json({ error: 'Database or Queue error', details: err.message });
  }
});

// 4. Route: Get all assets
app.get('/api/assets', async (req, res) => {
  try {
    if (!Asset) {
      return res.json([]);
    }
    const assets = await Asset.find({}).lean();
    res.json(assets);
  } catch (err: any) {
    res.status(500).json({ error: 'Query failed', details: err.message });
  }
});

// 5. Route: Health check
app.get('/health', async (req, res) => {
  const dbOk = mongoose.connection.readyState === 1;
  res.json({ ok: true, db: dbOk });
});

const PORT = 4000;
app.listen(PORT, () => {
  console.log(`🚀 API ready at http://localhost:${PORT}`);
});